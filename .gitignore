# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# next.js
/.next/
/out/

# env & secrets (never commit)
.env
.env*.local

# npm local config overrides
.npmrc.local

# python ingest venv (maintainers only)
.venv/

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# typescript
*.tsbuildinfo

# os
.DS_Store
Thumbs.db

# local dev reports (not needed for judges)
data/generated/lighthouse-*.json
data/generated/evaluation-report.*
data/generated/retrieval-evaluation-report.*

# python bytecode cache (maintainers only)
__pycache__/
*.pyc
